{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prettier-format.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/i18n-sync-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tsc-check.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
